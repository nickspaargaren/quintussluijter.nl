{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 10:00 on Monday"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchFiles": ["package.json"],
      "postUpgradeTasks": {
        "commands": ["deno install"],
        "fileFilters": ["deno.lock"]
      }
    }
  ]
}
